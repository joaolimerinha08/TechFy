.login-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #0f0f0f;
  padding: 20px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
}

.login-card {
  width: 100%;
  max-width: 500px;
  background-color: #1a1f3a;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4);
}

.header {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  padding: 40px 20px;
  text-align: center;
  color: white;
  position: relative;
}

.icon-circle {
  width: 80px;
  height: 80px;
  background-color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 20px;
  font-size: 45px;
}

.header h1 {
  font-size: 28px;
  font-weight: 600;
  margin: 0 0 8px 0;
  letter-spacing: 0.5px;
}

.header p {
  font-size: 14px;
  margin: 0;
  opacity: 0.95;
}

form {
  padding: 40px 30px;
}

.form-group {
  margin-bottom: 24px;
}

.form-group > label {
  display: none;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.label-row label {
  font-size: 13px;
  font-weight: 500;
  color: #e2e8f0;
}

.forgot-password {
  font-size: 13px;
  color: #3b82f6;
  text-decoration: none;
  transition: color 0.2s;
}

.forgot-password:hover {
  color: #60a5fa;
  text-decoration: underline;
}

.full-width {
  width: 100%;
}

::ng-deep .mat-mdc-form-field {
  width: 100%;
}

::ng-deep .mat-mdc-form-field-label {
  color: #64748b !important;
}

::ng-deep .mat-mdc-text-field-wrapper {
  background-color: transparent;
}

::ng-deep .mdc-text-field {
  background-color: #0f172a;
}

::ng-deep .mdc-text-field__input {
  color: #e2e8f0;
}

::ng-deep .mdc-text-field__input::placeholder {
  color: #64748b;
}

::ng-deep .mdc-notched-outline__leading,
::ng-deep .mdc-notched-outline__notch,
::ng-deep .mdc-notched-outline__trailing {
  border-color: #334155;
}

::ng-deep .mat-mdc-form-field.mat-focused .mdc-notched-outline__leading,
::ng-deep .mat-mdc-form-field.mat-focused .mdc-notched-outline__notch,
::ng-deep .mat-mdc-form-field.mat-focused .mdc-notched-outline__trailing {
  border-color: #3b82f6;
}

::ng-deep .mat-mdc-icon {
  color: #64748b;
}

.btn-login {
  width: 100%;
  margin-top: 8px !important;
  padding: 12px !important;
  font-size: 15px !important;
  font-weight: 500 !important;
  border-radius: 6px !important;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%) !important;
}

.btn-login:hover {
  box-shadow: 0 6px 20px rgba(59, 130, 246, 0.3) !important;
}

.footer-text {
  text-align: center;
  font-size: 12px;
  color: #64748b;
  margin: 24px 0 0 0;
  padding-top: 16px;
  border-top: 1px solid #334155;

  height: 100vh;
}

/* CARD */
.login-card {
  width: 400px;
  background: #0b1a33;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 10px 40px rgba(0,0,0,0.5);
}

/* HEADER */
.header {
  background: linear-gradient(180deg, #2d6cff, #1e4fd8);
  padding: 40px 20px;
  text-align: center;
  color: white;
}

.icon-circle {
  width: 60px;
  height: 60px;
  background: white;
  color: #2d6cff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 10px;
  font-size: 24px;
}

.header h1 {
  margin: 10px 0 5px;
  font-size: 22px;
}

.header p {
  margin: 0;
  font-size: 14px;
  opacity: 0.9;
}

/* FORM */
form {
  padding: 25px;
}

.form-group {
  margin-bottom: 20px;
}

label {
  color: #cbd5e1;
  font-size: 14px;
}

.label-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
}

.forgot-password {
  color: #3b82f6;
  font-size: 13px;
  text-decoration: none;
}

/* INPUT */
.input-group {
  display: flex;
  align-items: center;
  background: #000;
  border-radius: 8px;
  padding: 10px;
}

.input-icon {
  margin-right: 10px;
}

input {
  background: transparent;
  border: none;
  outline: none;
  color: white;
  width: 100%;
}

/* BUTTON */
.btn-login {
  width: 100%;
  padding: 14px;
  background: #2563eb;
  border: none;
  border-radius: 8px;
  color: white;
  font-weight: bold;
  cursor: pointer;
  margin-top: 10px;
}

.btn-login:hover {
  background: #1e4fd8;
}

/* FOOTER */
.footer-text {
  text-align: center;
  font-size: 12px;
  color: #94a3b8;
  padding: 15px;
}
